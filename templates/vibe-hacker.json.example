{
  "greenfield_mode": false,
  "debug_mode": false,
  "greenfield_patterns": [
    "deprecated",
    "legacy",
    "@deprecated",
    "TODO"
  ],
  "priming": {
    "files": [
      "README.md",
      "docs/ARCHITECTURE.md"
    ],
    "globs": [
      "docs/planning/decisions/*.md",
      "docs/planning/action-plans/AP-*-*.md"
    ],
    "instructions": "Focus on active action plans and pending decisions."
  },
  "planning": {
    "version": "0.2.1",
    "subdirs": {
      "adr": "decisions",
      "fdp": "designs",
      "ap": "action-plans",
      "report": "reports"
    }
  },
  "protected_paths": {
    "planning_root": "docs/planning",
    "rules": [
      {
        "pattern": "docs/planning/*/archive/**",
        "tier": "readonly",
        "message": "Archived documents are read-only historical records."
      },
      {
        "pattern": "docs/planning/decisions/[0-9][0-9][0-9]-*.md",
        "tier": "remind",
        "skill": "planning",
        "message": "Consider using the planning skill scripts to update status or archive ADRs."
      },
      {
        "pattern": "docs/planning/designs/FDP-*.md",
        "tier": "remind",
        "skill": "planning",
        "message": "Consider using the planning skill scripts to update status or archive FDPs."
      },
      {
        "pattern": "docs/planning/action-plans/AP-*.md",
        "tier": "remind",
        "skill": "planning",
        "message": "Consider using the planning skill scripts to update status or archive action plans."
      },
      {
        "pattern": "docs/planning/reports/RPT-*.md",
        "tier": "remind",
        "skill": "planning",
        "message": "Consider using the planning skill scripts to update status or archive reports."
      },
      {
        "pattern": "templates/**",
        "tier": "remind",
        "message": "This is a template file. Ensure placeholders are preserved."
      }
    ]
  },
  "agents": {
    "setup": "source .venv/bin/activate",
    "build_verifier": {
      "hints": "Describe your build system here",
      "commands": {
        "configure": "cmake --preset {preset} --fresh",
        "build": "cmake --build build/{preset}",
        "size": "arm-none-eabi-size build/{preset}/{name}.elf"
      }
    },
    "test_runner": {
      "suites": [
        {"name": "Unit tests", "cmd": "cd test && cmake -B build && cmake --build build && ctest --test-dir build"}
      ]
    },
    "arch_auditor": {
      "source_root": "src",
      "rules": [
        "core/ must NOT include app/",
        "hal/ MAY include core/ (intentional)"
      ]
    },
    "size_tracker": {
      "commands": {"size": "arm-none-eabi-size"},
      "baselines": [
        {"project": "examples/blinker", "preset": "target", "text": 1024}
      ],
      "threshold_pct": 5
    },
    "brainstorm": {
      "output_dir": "docs/planning/temp",
      "context_files": ["docs/architecture.md", "docs/planning/roadmap.md"]
    }
  }
}
